            "url": { "raw": "{{baseUrl}}/api/admin/users/1/profile", "host": ["{{baseUrl}}"], "path": ["api","admin","users","1","profile"] },
            "description": "Replace '1' with the actual user ID."
          }
        },
        {
          "name": "Assign Role to User",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization",  "value": "Bearer {{token}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"TECHNICIAN\"\n}"
