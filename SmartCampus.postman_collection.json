            "url": { "raw": "{{baseUrl}}/api/admin/users/1/role", "host": ["{{baseUrl}}"], "path": ["api","admin","users","1","role"] },
            "description": "Valid roles: USER, ADMIN, TECHNICIAN. Replace '1' with user ID."
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/users/1", "host": ["{{baseUrl}}"], "path": ["api","admin","users","1"] },
            "description": "Replace '1' with the user ID to delete."
          }
