{
  "info": {
    "name": "Smart Campus Operations API",
    "_postman_id": "smart-campus-2026",
    "description": "Complete API collection for Smart Campus Operations. Login first — token auto-saves to {{token}} and is used by all other requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "token",   "value": "",                     "type": "string" }
  ],
  "item": [

    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Login via Google OAuth2 (browser flow)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/oauth2/authorization/google", "host": ["{{baseUrl}}"], "path": ["oauth2","authorization","google"] },
            "description": "Open this URL in a browser to complete Google OAuth2 login. After login, the backend redirects to the frontend with a JWT token in the URL. Copy that token and set it in the collection variable 'token', OR use the Set Token request below."
          }
        },
        {
          "name": "Set Token Manually",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Paste your JWT token as the value of the 'token' variable",
                  "// in the collection variables panel (top-right 'Variables' tab).",
                  "// All requests will then use it automatically via {{token}}."
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api","auth","me"] },
            "description": "Paste your JWT token in the collection Variables panel under 'token'. This request verifies it works."
          }
        },
        {
          "name": "Get Current User (me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api","auth","me"] },
            "description": "Returns the currently authenticated user's profile."
          }
        }
      ]
    },

    {
      "name": "👤 Profile",
      "item": [
        {
          "name": "Update My Profile",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name",        "value": "John Doe",          "type": "text" },
                { "key": "phone",       "value": "+94771234567",       "type": "text" },
                { "key": "address",     "value": "123 Campus Road",    "type": "text" },
                { "key": "removePhoto", "value": "false",              "type": "text" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/api/profile", "host": ["{{baseUrl}}"], "path": ["api","profile"] }
          }
        },
        {
          "name": "Update Profile With Photo",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name",  "value": "John Doe", "type": "text" },
                { "key": "photo", "type": "file",      "src": "" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/api/profile", "host": ["{{baseUrl}}"], "path": ["api","profile"] },
            "description": "Select a file for the 'photo' field."
          }
        },
        {
          "name": "Remove Profile Photo",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "removePhoto", "value": "true", "type": "text" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/api/profile", "host": ["{{baseUrl}}"], "path": ["api","profile"] }
          }
        }
      ]
    },

    {
      "name": "👥 Admin — Users",
      "item": [
        {
          "name": "List All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/users", "host": ["{{baseUrl}}"], "path": ["api","admin","users"] }
