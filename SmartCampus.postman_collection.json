        },
        {
          "name": "Edit User Profile (Admin)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name",    "value": "Updated Name", "type": "text" },
                { "key": "phone",   "value": "+94771234567", "type": "text" },
                { "key": "address", "value": "New Address",  "type": "text" }
              ]
